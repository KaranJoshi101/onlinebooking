# PostgreSQL Database Configuration
# Copy this file to .env and customize with your PostgreSQL credentials

# Optional: paste the full Supabase connection string here
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# PostgreSQL User (default: postgres)
DB_USER=postgres

# PostgreSQL Password
DB_PASSWORD=your_secure_password_here

# PostgreSQL Host (default: localhost)
DB_HOST=localhost

# PostgreSQL Port (default: 5432)
DB_PORT=5432

# Database Name (default: onlinebooking)
DB_NAME=onlinebooking

# Use PostgreSQL instead of SQLite (True/False)
USE_POSTGRES=True

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your_secret_key_here

# Upload Folder for Images
UPLOAD_FOLDER=./static/images

# SMTP Mail Settings (OTP and booking notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_smtp_username@example.com
SMTP_PASSWORD=your_smtp_app_password
SMTP_SENDER=BookYourDoctor <your_smtp_username@example.com>
SMTP_USE_SSL=True
SMTP_USE_TLS=False
